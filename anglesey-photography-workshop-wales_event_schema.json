          "reviewRating": {
            "@type": "Rating",
            "ratingValue": "4",
            "bestRating": "5",
            "worstRating": "1"
          },
          "reviewBody": "A great few informative days With Alan in Wales on a workshop.  Alan managed to find places to photograph despite the dreadful weather.  Will definitely book to go on another workshop.",
          "datePublished": ""
        },
        {
          "@type": "Review",
          "author": {
            "@type": "Person",
