        },
        {
          "@type": "Review",
          "author": {
            "@type": "Person",
            "name": "Ian Pocock"
          },
          "reviewBody": "Alan provided a most enlightening day course on the theory and practice of woodland photography and the maximisation of the photos captured during a morning in the woods. He delivered all parts of the day with clarity and good humour to make it a most enjoyable and rewarding experience.",
          "reviewRating": {
